{
  "name": "platform",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.1.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --env-file=.env turbo run dev",
    "build": "bun run --env-file=.env turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@platform/db",
    "db:migrate": "turbo run db:migrate --filter=@platform/db",
    "db:push": "turbo run db:push --filter=@platform/db",
    "db:studio": "turbo run db:studio --filter=@platform/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "next-intl": "^4.9.0",
    "next-themes": "^0.4.6"
  }
}
